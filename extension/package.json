{
  "name": "adapto",
  "displayName": "Adapto",
  "description": "Full IDE support for the Adapto web framework — syntax highlighting, LSP diagnostics, completions, preview, and CLI integration for .adapto files",
  "version": "0.1.0",
  "publisher": "adapto",
  "author": {
    "name": "Saken Tukenov",
    "email": "gorgtown@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stukenov/adapto-vscode"
  },
  "homepage": "https://github.com/stukenov/adapto-vscode#readme",
  "bugs": {
    "url": "https://github.com/stukenov/adapto-vscode/issues"
  },
  "license": "MIT",
  "icon": "icons/adapto-icon.png",
  "galleryBanner": {
    "color": "#1E2340",
    "theme": "dark"
  },
  "keywords": [
    "adapto",
    "web framework",
    "rust",
    "template",
    "ssr",
    "full-stack"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Themes",
    "Snippets",
    "Formatters",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:adapto"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Adapto",
      "properties": {
        "adapto.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Adapto Language Server for diagnostics, completions, hover, and formatting."
        },
        "adapto.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Custom path to the adapto-lsp binary. Leave empty for auto-detection."
        },
        "adapto.preview.autoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the preview panel when an .adapto file is opened."
        },
        "adapto.format.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format .adapto files on save."
        },
        "adapto.devServer.port": {
          "type": "number",
          "default": 3000,
          "description": "Default port for the Adapto dev server."
        },
        "adapto.blockIndicators.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show block indicator icons in the status bar."
        },
        "adapto.controlFlowHighlight.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Highlight matched control flow pairs ({#if}/{/if}, {#each}/{/each}, etc.)."
        },
        "adapto.securityLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline annotations for #[permission] and #[audit] decorators."
        },
        "adapto.blockSeparators.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show visual separators between top-level blocks."
        }
      }
    },
    "languages": [
      {
        "id": "adapto",
        "aliases": ["Adapto", "adapto"],
        "extensions": [".adapto"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "adapto",
        "scopeName": "source.adapto",
        "path": "./syntaxes/adapto.tmLanguage.json",
        "embeddedLanguages": {
          "source.rust": "rust",
          "source.css": "css",
          "text.html.basic": "html"
        }
      }
    ],
    "snippets": [
      {
        "language": "adapto",
        "path": "./snippets/adapto.json"
      }
    ],
    "commands": [
      { "command": "adapto.newProject", "title": "Adapto: New Project" },
      { "command": "adapto.startDevServer", "title": "Adapto: Start Dev Server" },
      { "command": "adapto.stopDevServer", "title": "Adapto: Stop Dev Server" },
      { "command": "adapto.build", "title": "Adapto: Build" },
      { "command": "adapto.check", "title": "Adapto: Check" },
      { "command": "adapto.generateResource", "title": "Adapto: Generate Resource" },
      { "command": "adapto.showRoutes", "title": "Adapto: Show Routes" },
      { "command": "adapto.doctor", "title": "Adapto: Doctor" },
      {
        "command": "adapto.openPreview",
        "title": "Adapto: Open Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "adapto.openPreview",
          "when": "resourceLangId == adapto",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adapto",
          "title": "Adapto",
          "icon": "icons/adapto-icon.png"
        }
      ]
    },
    "themes": [
      {
        "label": "Adapto Night",
        "uiTheme": "vs-dark",
        "path": "./themes/adapto-dark.json"
      },
      {
        "label": "Adapto Day",
        "uiTheme": "vs",
        "path": "./themes/adapto-light.json"
      }
    ],
    "views": {
      "adapto": [
        {
          "id": "adaptoExplorer",
          "name": "Explorer"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
