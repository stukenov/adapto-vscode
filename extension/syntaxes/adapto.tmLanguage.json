{
  "name": "Adapto",
  "scopeName": "source.adapto",
  "fileTypes": ["adapto"],
  "patterns": [
    { "include": "#route-block" },
    { "include": "#script-block" },
    { "include": "#template-block" },
    { "include": "#style-block" },
    { "include": "#resource-block" },
    { "include": "#layout-block" },
    { "include": "#comment" }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.html.adapto",
      "begin": "<!--",
      "end": "-->"
    },

    "route-block": {
      "name": "meta.block.route.adapto",
      "begin": "(<)(route)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.route.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(route)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.route.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        { "include": "#route-content" }
      ]
    },
    "route-content": {
      "patterns": [
        {
          "match": "^\\s*(path|method|layout|page_title|auth|role|permission|tenant|cache|error|not_found)\\s*(:)",
          "captures": {
            "1": { "name": "variable.other.property.adapto" },
            "2": { "name": "punctuation.separator.key-value.adapto" }
          }
        },
        {
          "match": "\\b(public|required|verified|none|optional|no_store|private|static|get|post|put|delete|patch)\\b",
          "name": "constant.language.adapto"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.adapto"
        }
      ]
    },

    "script-block": {
      "name": "meta.block.script.adapto",
      "begin": "(<)(script)(\\s+lang\\s*=\\s*\"rust\")?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.script.adapto" },
        "3": { "name": "entity.other.attribute-name.adapto" },
        "4": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.script.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        { "include": "#script-keywords" },
        { "include": "#decorators" },
        { "include": "source.rust" }
      ]
    },
    "script-keywords": {
      "patterns": [
        {
          "match": "\\b(state)\\b",
          "name": "keyword.other.state.adapto"
        },
        {
          "match": "\\b(prop)\\b",
          "name": "keyword.other.prop.adapto"
        },
        {
          "match": "\\b(memo)\\b",
          "name": "keyword.other.memo.adapto"
        },
        {
          "match": "\\b(load)\\b",
          "name": "keyword.other.load.adapto"
        },
        {
          "match": "\\b(action)\\b",
          "name": "keyword.other.action.adapto"
        },
        {
          "match": "\\b(server)\\b",
          "name": "keyword.other.server.adapto"
        },
        {
          "match": "\\b(form)\\b",
          "name": "keyword.other.form.adapto"
        },
        {
          "match": "\\b(ai_action)\\b",
          "name": "keyword.other.ai-action.adapto"
        },
        {
          "match": "\\b(async|fn|use|struct|let|mut)\\b",
          "name": "keyword.other.rust"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.attribute.adapto",
          "match": "(#\\[)(permission|audit)(\\()(\"[^\"]*\")(\\))(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.attribute.begin.adapto" },
            "2": { "name": "entity.name.function.decorator.adapto" },
            "3": { "name": "punctuation.definition.arguments.begin.adapto" },
            "4": { "name": "string.quoted.double.decorator.adapto" },
            "5": { "name": "punctuation.definition.arguments.end.adapto" },
            "6": { "name": "punctuation.definition.attribute.end.adapto" }
          }
        }
      ]
    },

    "template-block": {
      "name": "meta.block.template.adapto",
      "begin": "(<)(template)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.template.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.template.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        { "include": "#template-content" }
      ]
    },
    "template-content": {
      "patterns": [
        { "include": "#control-flow" },
        { "include": "#unsafe-html" },
        { "include": "#expression" },
        { "include": "#component-tag" },
        { "include": "#html-self-closing-tag" },
        { "include": "#html-tag" },
        { "include": "#tag-attributes" },
        { "include": "#comment" }
      ]
    },

    "control-flow": {
      "patterns": [
        {
          "name": "meta.control.if.begin.adapto",
          "match": "(\\{)(#if)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.if.adapto" },
            "3": { "name": "meta.control.condition.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "name": "meta.control.each.begin.adapto",
          "match": "(\\{)(#each)\\b\\s+([a-zA-Z_][a-zA-Z0-9_.]*)\\s+(as)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:\\s*,\\s*([a-zA-Z_][a-zA-Z0-9_]*))?(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.each.adapto" },
            "3": { "name": "variable.other.iterable.adapto" },
            "4": { "name": "keyword.operator.as.adapto" },
            "5": { "name": "variable.other.iterator.adapto" },
            "6": { "name": "variable.other.index.adapto" },
            "7": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "name": "meta.control.each.begin.adapto",
          "match": "(\\{)(#each)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.each.adapto" },
            "3": { "name": "meta.control.iterable.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "name": "meta.control.match.begin.adapto",
          "match": "(\\{)(#match)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.match.adapto" },
            "3": { "name": "meta.control.expression.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "name": "meta.control.can.begin.adapto",
          "match": "(\\{)(#can)\\b\\s*(\"[^\"]*\")(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.can.adapto" },
            "3": { "name": "string.quoted.double.permission.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "name": "meta.control.can.begin.adapto",
          "match": "(\\{)(#can)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.can.adapto" },
            "3": { "name": "meta.control.expression.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "match": "(\\{)(:else\\s+if)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.else-if.adapto" },
            "3": { "name": "meta.control.condition.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "match": "(\\{)(:else)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.else.adapto" },
            "3": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "match": "(\\{)(:when)\\b\\s*([^}]*)(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.when.adapto" },
            "3": { "name": "meta.control.pattern.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        },
        {
          "match": "(\\{)(/(if|each|match|can))(\\})",
          "captures": {
            "1": { "name": "punctuation.definition.control.begin.adapto" },
            "2": { "name": "keyword.control.end.adapto" },
            "4": { "name": "punctuation.definition.control.end.adapto" }
          }
        }
      ]
    },

    "expression": {
      "name": "meta.expression.adapto",
      "begin": "\\{(?!#|/|:|@)",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.expression.begin.adapto" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.expression.end.adapto" }
      },
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.adapto"
        },
        {
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
          "name": "constant.numeric.adapto"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.adapto"
        },
        {
          "match": "(&&|\\|\\||!|==|!=|>=|<=|>|<)",
          "name": "keyword.operator.comparison.adapto"
        },
        {
          "match": "[a-zA-Z_][a-zA-Z0-9_.]*",
          "name": "variable.other.adapto"
        }
      ]
    },

    "unsafe-html": {
      "name": "meta.unsafe-html.adapto",
      "match": "(\\{)(@html)\\s+([^}]+)(\\})",
      "captures": {
        "1": { "name": "punctuation.definition.expression.begin.adapto" },
        "2": { "name": "keyword.operator.unsafe.adapto" },
        "3": { "name": "variable.other.adapto" },
        "4": { "name": "punctuation.definition.expression.end.adapto" }
      }
    },

    "component-tag": {
      "patterns": [
        {
          "match": "(</?)(\\b[A-Z][a-zA-Z0-9]*\\b)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.adapto" },
            "2": { "name": "entity.name.type.component.adapto" }
          }
        }
      ]
    },

    "html-self-closing-tag": {
      "match": "(<)(\\b(?:area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\\b)([^>]*?)(/?>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.html.adapto" },
        "4": { "name": "punctuation.definition.tag.end.adapto" }
      }
    },

    "html-tag": {
      "patterns": [
        {
          "match": "(</?)(\\b[a-z][a-z0-9-]*\\b)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.adapto" },
            "2": { "name": "entity.name.tag.html.adapto" }
          }
        }
      ]
    },

    "tag-attributes": {
      "patterns": [
        {
          "match": "\\b(on):(\\w+)(?:\\.(prevent|stop|debounce|throttle|once|capture|self)(?:\\.(\\d+))?)*",
          "captures": {
            "1": { "name": "keyword.operator.event.adapto" },
            "2": { "name": "entity.name.function.event.adapto" },
            "3": { "name": "support.function.modifier.adapto" },
            "4": { "name": "constant.numeric.adapto" }
          }
        },
        {
          "match": "\\b(bind):(\\w+)",
          "captures": {
            "1": { "name": "keyword.operator.binding.adapto" },
            "2": { "name": "variable.other.binding.adapto" }
          }
        },
        {
          "match": "\\b(island)\\b",
          "name": "keyword.other.island.adapto"
        },
        {
          "match": "\\b(class|id|style|href|src|alt|type|name|value|placeholder|disabled|readonly|for|action|method|target|rel|role|aria-[a-z]+|data-[a-z-]+)\\b(?=\\s*=)",
          "name": "entity.other.attribute-name.html.adapto"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.adapto"
        }
      ]
    },

    "style-block": {
      "name": "meta.block.style.adapto",
      "begin": "(<)(style)(\\s+(?:scoped|global))?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.style.adapto" },
        "3": { "name": "keyword.other.scope.adapto" },
        "4": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(style)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.style.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        { "include": "source.css" }
      ]
    },

    "resource-block": {
      "name": "meta.block.resource.adapto",
      "begin": "(<)(resource)(\\s+[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.resource.adapto" },
        "3": { "name": "entity.other.attribute-name.adapto" },
        "4": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(resource)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.resource.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        { "include": "#resource-content" }
      ]
    },
    "resource-content": {
      "patterns": [
        {
          "match": "\\b(field|permission|tenant|primary_key)\\b",
          "name": "keyword.other.resource.adapto"
        },
        {
          "match": "@(email|required|min|max|unique|optional|searchable|readonly|pattern|length|range|default)\\b(?:\\(([^)]*)\\))?",
          "captures": {
            "0": { "name": "support.function.constraint.adapto" },
            "2": { "name": "constant.other.constraint-arg.adapto" }
          }
        },
        {
          "match": "\\b(String|Integer|Float|Boolean|DateTime|Uuid|Json|Text|Email|Phone|Url|Enum)\\b",
          "name": "support.type.adapto"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.adapto"
        }
      ]
    },

    "layout-block": {
      "name": "meta.block.layout.adapto",
      "begin": "(<)(layout)(\\s+[^>]*)?(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.layout.adapto" },
        "3": { "name": "entity.other.attribute-name.adapto" },
        "4": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "end": "(</)(layout)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.adapto" },
        "2": { "name": "entity.name.tag.layout.adapto" },
        "3": { "name": "punctuation.definition.tag.end.adapto" }
      },
      "patterns": [
        {
          "match": "\\b(name|auth|tenant)\\s*(:)",
          "captures": {
            "1": { "name": "variable.other.property.adapto" },
            "2": { "name": "punctuation.separator.key-value.adapto" }
          }
        },
        {
          "match": "\\b(public|required|verified|none|optional)\\b",
          "name": "constant.language.adapto"
        },
        {
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.adapto"
        }
      ]
    }
  }
}
